@page
@model PendingModel
@{
    ViewData["Title"] = "待审核用户";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5><i class="bi bi-clock-history"></i> 待审核用户列表</h5>
        </div>
        <div class="card-body">
            @if (Model.PendingUsers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>用户名</th>
                                <th>真实姓名</th>
                                <th>邮箱</th>
                                <th>部门</th>
                                <th>注册时间</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.PendingUsers)
                            {
                                <tr>
                                    <td>@user.UserName</td>
                                    <td>@user.RealName</td>
                                    <td>@user.Email</td>
                                    <td>@user.Department</td>
                                    <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a asp-page="./Approve" asp-route-id="@user.Id" 
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye"></i> 审核
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-check-circle" style="font-size: 3rem;"></i>
                    <p class="mt-3">暂无待审核用户</p>
                </div>
            }
        </div>
    </div>
</div>
