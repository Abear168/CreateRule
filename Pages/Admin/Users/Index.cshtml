@page
@model IndexModel
@using CreateRule.Models
@{
    ViewData["Title"] = "用户管理";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people"></i> 用户管理</h5>
        <a asp-page="./Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> 创建用户
        </a>
    </div>
    <div class="card-body">
        <form method="get" class="mb-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="searchString" value="@Model.SearchString"
                           class="form-control" placeholder="搜索工号或姓名">
                </div>
                <div class="col-md-3">
                    <select name="statusFilter" class="form-select">
                        <option value="">全部状态</option>
                        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">待审核</option>
                        <option value="Approved" selected="@(Model.StatusFilter == "Approved")">已通过</option>
                        <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">已拒绝</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> 搜索
                    </button>
                    <a asp-page="./Index" class="btn btn-secondary">重置</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>工号</th>
                        <th>姓名</th>
                        <th>邮箱</th>
                        <th>状态</th>
                        <th>注册时间</th>
                        <th>最后登录</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.EmployeeId</td>
                            <td>@user.RealName</td>
                            <td>@user.Email</td>
                            <td>
                                @switch (user.ApprovalStatus)
                                {
                                    case ApprovalStatus.Pending:
                                        <span class="badge bg-warning">待审核</span>
                                        break;
                                    case ApprovalStatus.Approved:
                                        <span class="badge bg-success">已通过</span>
                                        break;
                                    case ApprovalStatus.Rejected:
                                        <span class="badge bg-danger">已拒绝</span>
                                        break;
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "从未登录")</td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@user.Id" 
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@user.Id" 
                                   class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (user.UserName != "admin")
                                {
                                    <a asp-page="./Delete" asp-route-id="@user.Id" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('确定要删除此用户吗？')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-page="./Index" 
                               asp-route-pageIndex="@i" 
                               asp-route-searchString="@Model.SearchString"
                               asp-route-statusFilter="@Model.StatusFilter">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
