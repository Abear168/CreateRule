@page
@model IndexModel
@{
    ViewData["Title"] = "角色管理";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-shield"></i> 角色管理</h5>
        <a asp-page="./Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> 创建角色
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>角色名称</th>
                        <th>描述</th>
                        <th>创建时间</th>
                        <th>用户数量</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>@role.Name</td>
                            <td>@role.Description</td>
                            <td>@role.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@Model.GetUserCount(role.Id)</td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@role.Id" 
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (role.Name != "SuperAdmin" && role.Name != "Admin" && role.Name != "User")
                                {
                                    <a asp-page="./Delete" asp-route-id="@role.Id" 
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('确定要删除此角色吗？')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
