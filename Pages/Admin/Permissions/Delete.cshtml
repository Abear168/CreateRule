@page
@model DeleteModel
@{
    ViewData["Title"] = "删除权限";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h5><i class="bi bi-trash"></i> 删除权限</h5>
    </div>
    <div class="card-body">
        <h6>确定要删除以下权限吗？</h6>
        <dl class="row mt-3">
            <dt class="col-sm-2">权限代码</dt>
            <dd class="col-sm-10">@Model.Permission.Code</dd>

            <dt class="col-sm-2">权限名称</dt>
            <dd class="col-sm-10">@Model.Permission.Name</dd>

            <dt class="col-sm-2">所属模块</dt>
            <dd class="col-sm-10">@Model.Permission.Module ?? "其他"</dd>

            <dt class="col-sm-2">描述</dt>
            <dd class="col-sm-10">@Model.Permission.Description</dd>
        </dl>

        <form method="post">
            <input type="hidden" asp-for="Permission.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> 确认删除
            </button>
            <a asp-page="./Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> 取消
            </a>
        </form>
    </div>
</div>
