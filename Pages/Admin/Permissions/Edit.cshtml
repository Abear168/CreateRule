@page
@model EditModel
@{
    ViewData["Title"] = "编辑权限";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5><i class="bi bi-pencil"></i> 编辑权限</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Code" class="form-label">权限代码</label>
                    <input asp-for="Input.Code" class="form-control" readonly />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Name" class="form-label required">权限名称</label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Module" class="form-label">所属模块</label>
                    <input asp-for="Input.Module" class="form-control" />
                    <span asp-validation-for="Input.Module" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Description" class="form-label">描述</label>
                    <input asp-for="Input.Description" class="form-control" />
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> 保存
                </button>
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> 返回
                </a>
            </div>
        </form>
    </div>
</div>
