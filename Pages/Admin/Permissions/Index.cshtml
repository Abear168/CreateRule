@page
@model IndexModel
@{
    ViewData["Title"] = "权限管理";
}

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-key"></i> 权限管理</h5>
        <a asp-page="./Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> 创建权限
        </a>
    </div>
    <div class="card-body">
        @foreach (var module in Model.PermissionsByModule)
        {
            <div class="mb-4">
                <h6 class="text-primary border-bottom pb-2">
                    <i class="bi bi-folder"></i> @module.Key
                </h6>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>权限名称</th>
                                <th>权限代码</th>
                                <th>描述</th>
                                <th>创建时间</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var permission in module.Value)
                            {
                                <tr>
                                    <td>@permission.Name</td>
                                    <td><code>@permission.Code</code></td>
                                    <td>@permission.Description</td>
                                    <td>@permission.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-page="./Edit" asp-route-id="@permission.Id"
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-page="./Delete" asp-route-id="@permission.Id"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('确定要删除此权限吗？')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
