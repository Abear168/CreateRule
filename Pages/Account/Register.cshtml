@page
@model RegisterModel
@{
    ViewData["Title"] = "注册";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CreateRule</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 0;
        }
        .register-container {
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            padding: 40px;
            max-width: 500px;
            width: 100%;
        }
        .register-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .register-header h2 {
            color: #333;
            margin-bottom: 10px;
        }
        .register-header p {
            color: #666;
        }
        .form-control {
            border-radius: 5px;
            padding: 12px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 5px;
            padding: 12px;
            font-weight: 600;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
        }
        .form-label.required::after {
            content: " *";
            color: red;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-header">
            <h2>注册账号</h2>
            <p>创建您的 CreateRule 账号</p>
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.EmployeeId" class="form-label required">工号</label>
                <input asp-for="Input.EmployeeId" class="form-control" placeholder="请输入工号" />
                <span asp-validation-for="Input.EmployeeId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.RealName" class="form-label required">姓名</label>
                <input asp-for="Input.RealName" class="form-control" placeholder="请输入姓名" />
                <span asp-validation-for="Input.RealName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label required">邮箱</label>
                <input asp-for="Input.Email" type="email" class="form-control" placeholder="请输入邮箱" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label required">密码</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="请输入密码（至少6位）" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ConfirmPassword" class="form-label required">确认密码</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="请再次输入密码" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">提交注册申请</button>

            <div class="text-center">
                <a asp-page="./Login" class="text-decoration-none">已有账号？立即登录</a>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
