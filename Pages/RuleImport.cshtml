@page
@model RuleImportModel
@{
    ViewData["Title"] = "规则导入";
}

<div class="container mt-4">
    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <span>@error.ErrorMessage</span>
                <br />
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5>筛选条件</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Filter">
                <input type="hidden" name="pageIndex" value="1" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="projectName" class="form-label">项目名称</label>
                        <input type="text" class="form-control" id="projectName"
                               asp-for="FilterModel.ProjectName" placeholder="请输入项目名称">
                    </div>

                    <div class="col-md-3">
                        <label for="matchString" class="form-label">匹配字符串</label>
                        <input type="text" class="form-control" id="matchString"
                               asp-for="FilterModel.MatchString" placeholder="请输入匹配字符串">
                    </div>

                    <div class="col-md-3">
                        <label for="startTime" class="form-label">起始时间</label>
                        <input type="datetime-local" class="form-control" id="startTime"
                               asp-for="FilterModel.StartTime">
                    </div>

                    <div class="col-md-3">
                        <label for="endTime" class="form-label">结束时间</label>
                        <input type="datetime-local" class="form-control" id="endTime"
                               asp-for="FilterModel.EndTime">
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> 筛选
                    </button>
                    <a href="?handler=Reset" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i> 重置
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0">匹配结果列表</h5>
            <div>
                <span class="badge bg-success">已去重显示</span>
                <span class="badge bg-info ms-2">API数据源 共 @Model.Pagination.allCount 条数据</span>
                <span class="badge bg-warning ms-2">共 @Model.Pagination.TotalCount 条，当前第 @Model.Pagination.PageIndex 页</span>
            </div>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Generate" id="mainForm">
                <input type="hidden" name="pageIndex" value="@Model.Pagination.PageIndex" />
                
                <input type="hidden" asp-for="FilterModel.ProjectName" />
                <input type="hidden" asp-for="FilterModel.MatchString" />
                <input type="hidden" asp-for="FilterModel.StartTime" />
                <input type="hidden" asp-for="FilterModel.EndTime" />
                
                @foreach (var item in Model.MatchResults)
                {
                    <input type="hidden" name="itemIds" value="@item.Id" />
                    <input type="hidden" name="itemNames" value="@item.ProjectName" />
                    <input type="hidden" name="itemStartPositions" value="@item.StartPosition" />
                    <input type="hidden" name="itemEndPositions" value="@item.EndPosition" />
                    <input type="hidden" name="itemMatchStrings" value="@item.MatchString" />
                }

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 50px;">
                                    <input type="checkbox" id="selectAll" />
                                </th>
                                <th>项目名称</th>
                                <th>起始位置</th>
                                <th>结束位置</th>
                                <th>匹配字符串</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.MatchResults?.Any() == true)
                            {
                                @foreach (var item in Model.MatchResults)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="row-checkbox"
                                                   name="selectedIds" value="@item.Id" />
                                        </td>
                                        <td>@item.ProjectName</td>
                                        <td>@item.StartPosition</td>
                                        <td>@item.EndPosition</td>
                                        <td>
                                            <span class="badge bg-info text-wrap" style="max-width: 300px;">@item.MatchString</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                                        {
                                            <div>
                                                <i class="bi bi-info-circle fs-4"></i>
                                                <p class="mt-2">@Model.SuccessMessage</p>
                                                <small class="text-muted">仅显示重复出现2次以上的项目</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div>
                                                <i class="bi bi-exclamation-circle fs-4"></i>
                                                <p class="mt-2">暂无重复项目数据</p>
                                                <small class="text-muted">仅显示重复出现2次以上的项目</small>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Pagination.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(!Model.Pagination.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link"
                                   href="?handler=Filter&pageIndex=@(Model.Pagination.PageIndex - 1)&projectName=@Model.FilterModel.ProjectName&matchString=@Model.FilterModel.MatchString&startTime=@Model.FilterModel.StartTime?.ToString("yyyy-MM-ddTHH:mm")&endTime=@Model.FilterModel.EndTime?.ToString("yyyy-MM-ddTHH:mm")">
                                    上一页
                                </a>
                            </li>

                            @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Pagination.PageIndex ? "active" : "")">
                                    <a class="page-link"
                                       href="?handler=Filter&pageIndex=@i&projectName=@Model.FilterModel.ProjectName&matchString=@Model.FilterModel.MatchString&startTime=@Model.FilterModel.StartTime?.ToString("yyyy-MM-ddTHH:mm")&endTime=@Model.FilterModel.EndTime?.ToString("yyyy-MM-ddTHH:mm")">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(!Model.Pagination.HasNextPage ? "disabled" : "")">
                                <a class="page-link"
                                   href="?handler=Filter&pageIndex=@(Model.Pagination.PageIndex + 1)&projectName=@Model.FilterModel.ProjectName&matchString=@Model.FilterModel.MatchString&startTime=@Model.FilterModel.StartTime?.ToString("yyyy-MM-ddTHH:mm")&endTime=@Model.FilterModel.EndTime?.ToString("yyyy-MM-ddTHH:mm")">
                                    下一页
                                </a>
                            </li>
                        </ul>
                    </nav>
                }

                <div class="d-flex justify-content-between mt-4">
                    <div>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-gear"></i> 生成
                        </button>
                        <span class="ms-2 text-muted" id="selectedCount">
                            已选择 0 项
                        </span>
                    </div>
                    
                    <div>
                        <div class="input-group" style="width: 200px;">
                            <span class="input-group-text">每页</span>
                            <select class="form-select" id="pageSizeSelect" style="width: auto;">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                            <span class="input-group-text">条</span>
                        </div>
                    </div>
                    
                    <div>
                        <a href="http://192.168.8.211:8006/" class="btn btn-link ms-2" id="ruleSettingsLink">
                            <i class="bi bi-question-circle"></i> 去规则设置
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let ruleSettingsWindow = null;
            document.getElementById('ruleSettingsLink').addEventListener('click', function(e) {
                e.preventDefault();
                const url = this.href;
                
                if (ruleSettingsWindow && !ruleSettingsWindow.closed) {
                    ruleSettingsWindow.focus();
                    if (ruleSettingsWindow.location.href !== url) {
                        ruleSettingsWindow.location.href = url;
                    }
                } else {
                    ruleSettingsWindow = window.open(url, 'RuleSettingsWindow', 'width=1200,height=800');
                    
                    if (ruleSettingsWindow) {
                        const checkWindow = setInterval(() => {
                            if (ruleSettingsWindow.closed) {
                                clearInterval(checkWindow);
                                ruleSettingsWindow = null;
                            }
                        }, 1000);
                    }
                }
            });

            $('#mainForm').submit(function() {
                $('#mainForm input[name="FilterModel.ProjectName"]').val($('#projectName').val());
                $('#mainForm input[name="FilterModel.MatchString"]').val($('#matchString').val());
                $('#mainForm input[name="FilterModel.StartTime"]').val($('#startTime').val());
                $('#mainForm input[name="FilterModel.EndTime"]').val($('#endTime').val());
            });
            
            $('#selectAll').change(function() {
                const isChecked = $(this).prop('checked');
                $('.row-checkbox').prop('checked', isChecked);
                updateSelectedCount();
            });

            $('.row-checkbox').change(function() {
                const allChecked = $('.row-checkbox:checked').length === $('.row-checkbox').length;
                $('#selectAll').prop('checked', allChecked);
                updateSelectedCount();
            });

            function updateSelectedCount() {
                const count = $('.row-checkbox:checked').length;
                $('#selectedCount').text('已选择 ' + count + ' 项');
            }

            $('#pageSizeSelect').change(function() {
                const pageSize = $(this).val();
                const currentUrl = new URL(window.location.href);
                currentUrl.searchParams.set('pageSize', pageSize);
                currentUrl.searchParams.set('pageIndex', 1);
                window.location.href = currentUrl.toString();
            });

            setTimeout(function() {
                $('.alert-success').fadeOut('slow');
            }, 5000);

            setTimeout(function() {
                $('.alert-danger').fadeOut('slow');
            }, 10000);

            updateSelectedCount();
        });
    </script>
}
