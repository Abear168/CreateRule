@page
@model DeleteModel
@{
    ViewData["Title"] = "删除规则";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h5><i class="bi bi-trash"></i> 删除规则</h5>
    </div>
    <div class="card-body">
        <h6>确定要删除以下规则吗？此操作不可恢复。</h6>
        <dl class="row mt-3">
            <dt class="col-sm-3">工单号</dt>
            <dd class="col-sm-9">@Model.Rule.WorkOrder</dd>

            <dt class="col-sm-3">规则模板</dt>
            <dd class="col-sm-9"><code>@Model.Rule.Template</code></dd>

            <dt class="col-sm-3">前缀</dt>
            <dd class="col-sm-9">@Model.Rule.Prefix</dd>

            <dt class="col-sm-3">前缀位数</dt>
            <dd class="col-sm-9">@Model.Rule.PrefixLength</dd>

            <dt class="col-sm-3">流水码位数</dt>
            <dd class="col-sm-9">@Model.Rule.SequenceLength</dd>
        </dl>

        <form method="post">
            <input type="hidden" asp-for="Rule.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> 确认删除
            </button>
            <a asp-page="./Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> 取消
            </a>
        </form>
    </div>
</div>
